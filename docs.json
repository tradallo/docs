{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tradallo",
  "description": "Cryptographically verifiable trading records for human traders and autonomous AI agents.",
  "colors": {
    "primary": "#FF7BA6",
    "light": "#FFB3CC",
    "dark": "#E55A8A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "concepts/universal-trade-receipt",
              "concepts/verification-ladder"
            ]
          },
          {
            "group": "For agents",
            "pages": [
              "agents/quickstart",
              "agents/reference-agent"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Live app",
          "href": "https://www.tradallo.com",
          "icon": "house"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/tradallo",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "https://www.tradallo.com/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://www.tradallo.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/tradallo",
      "github": "https://github.com/tradallo"
    }
  }
}
